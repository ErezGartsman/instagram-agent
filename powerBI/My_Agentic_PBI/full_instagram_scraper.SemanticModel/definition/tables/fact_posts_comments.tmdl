	column RunDate
		dataType: dateTime
		formatString: Long Date
		lineageTag: 71acdfd4-4641-463b-8b31-041ff4c7c50a
		summarizeBy: none
		sourceColumn: RunDate

		variation Variation
			isDefault
			relationship: 31b8326e-5bb9-46c1-8df8-25fc0342078f
			defaultHierarchy: LocalDateTable_69510268-c2f9-4929-a984-6ac166881e7f.'Date Hierarchy'

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition fact_posts_comments = m
		mode: import
		source =
				let
				    FolderPath = "C:\Users\Erez\OneDrive - Bar-Ilan University - Students\Desktop\instagram project\data\instagram_media",
				    Source = Folder.Files(FolderPath),
				    KeepComments = Table.SelectRows(Source, each [Name] = "batch_comments.csv" and [Extension] = ".csv"),
				    WithRunDate = Table.AddColumn(
				        KeepComments, "RunDate",
				        each try Date.FromText(Text.End(Text.TrimEnd([Folder Path], "\"), 10)) otherwise null,
				        type date
				    ),
				    ReadEach = Table.AddColumn(WithRunDate, "Data", each
				        let
				            raw   = Csv.Document([Content], [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				            hdr   = Table.PromoteHeaders(raw, [PromoteAllScalars=true]),
				            typed = Table.TransformColumnTypes(hdr,{
				                        {"post_shortcode", type text},
				                        {"username",      type text},
				                        {"comment",       type text},
				                        {"posted_at",     type any},
				                        {"media_url",     type text}
				                    }),
				            // --- FIX: also handle numeric-like TEXT ("1700915575") ---
				            addDT = Table.AddColumn(typed, "comment_datetime", (r) =>
				                    let
				                        v    = r[posted_at],
				                        vTxt = try Text.From(v) otherwise null,
				                        n    = if vTxt <> null then try Number.FromText(vTxt) otherwise null else null
				                    in
				                        if n <> null then
				                            // UNIX seconds -> datetime
				                            #datetime(1970,1,1,0,0,0) + #duration(0,0,0, n)
				                        else
				                            // try ISO text
				                            try DateTime.FromText(vTxt) otherwise null
				                , type datetime),
				            addRD = Table.AddColumn(addDT, "RunDate", (r)=> [RunDate], type date),
				            final = Table.SelectColumns(addRD, {
				                        "post_shortcode","username","comment","comment_datetime","media_url","RunDate"
				                    })
				        in  final
				    ),
				    Combined = Table.Combine(ReadEach[Data]),
				    #"Changed Type" = Table.TransformColumnTypes(Combined,{{"comment_datetime", type date}}),
				    #"Sorted Rows" = Table.Sort(#"Changed Type",{{"comment_datetime", Order.Descending}}),
				    #"Renamed Columns" = Table.RenameColumns(#"Sorted Rows",{{"comment_datetime", "comment_date"}}),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Renamed Columns",{{"post_shortcode", type text}, {"username", type text}, {"comment", type text}, {"comment_date", type date}, {"media_url", type text}, {"RunDate", type date}}),
				    #"Removed Duplicates" = Table.Distinct(#"Changed Type1", {"username", "comment", "media_url"}),
				    #"Removed Columns" = Table.RemoveColumns(#"Removed Duplicates",{"media_url"})
				in
				    #"Removed Columns"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

