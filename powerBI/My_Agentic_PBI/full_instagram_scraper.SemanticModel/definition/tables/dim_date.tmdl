table dim_date
	lineageTag: 8b0c073d-c616-40ea-af21-c23c45b1db96

	measure user = USERPRINCIPALNAME()
		isHidden
		displayFolder: Internal
		lineageTag: 53a8e643-811c-4063-a7ca-aacd77c68351

	column Date
		formatString: dd/mm/yyyy
		lineageTag: 1c07b314-c316-4d48-87c4-32f210e0e2c4
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		variation Variation
			isDefault
			relationship: dc90578d-0db2-4cf3-b3b6-94d920f401d5
			defaultHierarchy: LocalDateTable_14d27ac4-9b14-4cd8-bb22-2688c02a0185.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	column Year
		formatString: 0
		lineageTag: 291c248b-ac66-4ecc-b24d-f73fabf33f4b
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

