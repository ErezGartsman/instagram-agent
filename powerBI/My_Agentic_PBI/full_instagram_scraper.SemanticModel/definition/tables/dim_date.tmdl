		lineageTag: 68cbebd0-4e08-466a-a266-75025dd75695
		summarizeBy: none
		isNameInferred
		sourceColumn: [Month]
		sortByColumn: MonthNum

		annotation SummarizationSetBy = Automatic

	column MonthNum
		formatString: 0
		lineageTag: 4506fc37-2281-46f1-89d0-7343a40d05e6
		summarizeBy: sum
		isNameInferred
		sourceColumn: [MonthNum]

		annotation SummarizationSetBy = Automatic

	column Quarter
		lineageTag: 00a52899-d3dc-47a3-86b2-31d7ce7dd1c6
		summarizeBy: none
		isNameInferred
		sourceColumn: [Quarter]

