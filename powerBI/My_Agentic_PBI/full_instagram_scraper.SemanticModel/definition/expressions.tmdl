expression fact_followers =
		let
		    // === UPDATE THIS PATH IF NEEDED ===
		    FolderPath = "C:\Users\Erez\OneDrive - Bar-Ilan University - Students\Desktop\instagram project\data\instagram_followers",
		
		    // All files in subfolders
		    Source = Folder.Files(FolderPath),
		    #"Inserted Text After Delimiter" = Table.AddColumn(Source, "Text After Delimiter", each Text.AfterDelimiter([Folder Path], "instagram-erez_gersman-"), type text),
		    #"Extracted First Characters" = Table.TransformColumns(#"Inserted Text After Delimiter", {{"Text After Delimiter", each Text.Start(_, 10), type text}}),
		    #"Changed Type1" = Table.TransformColumnTypes(#"Extracted First Characters",{{"Text After Delimiter", type date}}),
		    #"Renamed Columns1" = Table.RenameColumns(#"Changed Type1",{{"Text After Delimiter", "Snapshot_Date"}}),
		    // Keep only followers_1.json / followers_2.json under ...\connections\followers_and_following\
		    KeepFollowers =
		        Table.SelectRows(
		            #"Renamed Columns1",
		            each [Extension] = ".json"
		                and (Text.Lower([Name]) = "followers_1.json" or Text.Lower([Name]) = "followers_2.json")
		                and Text.Contains(Text.Lower([Folder Path]), "\connections\followers_and_following")
		        ),
		
		    // Derive RunDate from folder segment "instagram-<user>-YYYY-MM-DD-<token>"
		    AddRunDate =
		        Table.AddColumn(
		            KeepFollowers, "RunDate", each
		                let
		                    pTrim   = Text.TrimEnd([Folder Path], "\"),
		                    seg     = List.Last(Text.Split(pTrim, "\")),
		                    bits    = Text.Split(seg, "-"),
		                    dateTxt = if List.Count(bits) >= 5 then bits{2} & "-" & bits{3} & "-" & bits{4} else null,
		                    dParsed = try Date.FromText(dateTxt) otherwise null
		                in  if dParsed <> null then dParsed else Date.From([Date created]),
		            type date
		        ),
		
		    // Parse JSON (each file is a List of records)
		    ReadJson   = Table.AddColumn(AddRunDate, "Json", each Json.Document([Content])),
		
		    // Turn list -> table with column "Item"
		    AsTable    = Table.TransformColumns(ReadJson, {{"Json", each Table.FromList(_, Splitter.SplitByNothing(), {"Item"})}}),
		
		    // Expand the table column "Json" to the single column "Item" (each Item is a record)
		    ExpandTable = Table.ExpandTableColumn(AsTable, "Json", {"Item"}, {"Item"}),
		
		    // Expand record fields from Item
		    ExpandItem  = Table.ExpandRecordColumn(
		                    ExpandTable, "Item",
		                    {"title","media_list_data","string_list_data"},
		                    {"title","media_list_data","string_list_data"}),
		
		    // string_list_data is a list -> expand to rows
		    ExpandList  = Table.ExpandListColumn(ExpandItem, "string_list_data"),
		
		    // Each element of string_list_data is a record {href,value,timestamp}
		    ExpandStr   = Table.ExpandRecordColumn(ExpandList, "string_list_data",
		                    {"href","value","timestamp"},
		                    {"username_url","username","follow_ts"}),
		
		    // Types
		    Typed1 = Table.TransformColumnTypes(ExpandStr, {
		        {"username", type text},
		        {"username_url", type text},
		        {"follow_ts", Int64.Type},
		        {"RunDate", type date}
		    }),
		
		    // UNIX seconds -> datetime
		    AddFollowDT = Table.AddColumn(
		        Typed1, "follow_datetime",
		        each if [follow_ts] <> null
		             then #datetime(1970,1,1,0,0,0) + #duration(0,0,0,[follow_ts])
		             else null,
		        type datetime
		    ),
		
		    // Keep useful cols
		    KeepCols = Table.SelectColumns(AddFollowDT, {"username","username_url","follow_datetime","RunDate"}),
		
		    // Deduplicate within the combined set (safety)
		    Dedup = Table.Distinct(KeepCols),
		    #"Changed Type" = Table.TransformColumnTypes(Dedup,{{"follow_datetime", type date}}),
		    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{"follow_datetime", "follow_date"}})
		in
		    #"Renamed Columns"
	lineageTag: 11b7cb80-4757-457c-9768-cd889f2a1cdb

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

