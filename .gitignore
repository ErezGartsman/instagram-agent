*.db
*.duckdb
*.db-shm
*.db-wal

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
audit.log

# ─── Data files (may contain PII) ────────────────────────────────────────────
data/

# ─── Python runtime ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ─── Virtual environments ────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ─── Distribution / packaging ────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ─── Type checking ───────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ─── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─── Editors & OS ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── DuckDB CLI binary (not source, belongs in PATH not the repo) ─────────────
duckdb.exe
duckdb


# ─── Catch-all for massive data files ───────────────────────────────────────
*.csv
*.json
*.parquet
*.xlsx
archive/

*.exe
*.zip

# ─── Exceptions — config/manifest files that are JSON but must be tracked ────
# (Git processes negations in order, so these must come AFTER the *.json rule)
!vercel.json
!package.json
!package-lock.json
!tsconfig*.json
!.eslintrc.json
!*.eslintrc.json

# ─── Test output ─────────────────────────────────────────────────────────────
test-results.xml

