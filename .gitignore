# ─── Secrets & Config ────────────────────────────────────────────────────────
.env
.env.*
# Ad-hoc secret/credential notes kept beside the project (e.g.
# "# DataLens — Environment Variables.txt"). Never commit these.
*Environment Variables*.txt
*secrets*.txt
*credentials*.txt
# Negations below MUST be on their own line — a trailing "# comment" becomes
# part of the pattern and silently breaks the rule.
# keep the example template in git (no secrets, just placeholders)
!.env.example
# safe to commit — only contains public URLs, no secrets
!.env.production

# ─── Python & Virtual Environments ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
venv/
.venv/
env/
.env/
ENV/

# ─── Database Files & Binaries ───────────────────────────────────────────────
*.db
*.duckdb
*.db-shm
*.db-wal
duckdb.exe
duckdb
*.exe
*.zip

# ─── Massive Data Files & PII ────────────────────────────────────────────────
data/
archive/
# private business knowledge base (RAG source) — never commit
beckend/knowledge/
*.csv
*.parquet
*.xlsx
*.json

# ─── JSON Exceptions (MUST come after *.json) ────────────────────────────────
!vercel.json
!package.json
!package-lock.json
!tsconfig*.json
!.eslintrc.json
!*.eslintrc.json
# Cockpit design artifacts (source, not data) — e.g. the Power BI theme.
!fronted/src/cockpit/**/*.json

# ─── Unrelated Projects, Infra & Excluded Folders ────────────────────────────
מחקר חברות AI/
Social POC*/
