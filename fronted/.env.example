# ── NEXUS Cockpit (Supabase) ─────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. VITE_SUPABASE_ANON_KEY is the browser-safe *publishable* anon key
# (NOT the service_role secret) — it is protected by Row Level Security.
#
# For production, set these two as Vercel project env vars (do not commit them).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Legacy Nexus backend (/legacy app) ───────────────────────────────────────
# Already provided in .env.production; only override locally if needed.
# VITE_API_BASE=https://instagram-agent-seven.vercel.app
