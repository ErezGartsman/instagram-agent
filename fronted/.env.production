# Production environment — values here are baked into the Vite bundle at build time.
# VITE_* variables are safe to commit (they end up in public JS anyway).
# This file ensures the correct backend URL is always embedded even if the
# Vercel dashboard env var is set after the build runs.

VITE_API_BASE=https://instagram-agent-seven.vercel.app

# Sprint 5 · P0 ② (2026-06-23): the Work Queue is LIVE in production — the
# Decision Engine's core surface (ranked queue + the Action Loop). Migration
# v1_006 (opportunities.snoozed_until) was applied first, so the queue's snooze
# filter is safe. Flip back to remove from prod.
VITE_FEATURE_WORKQUEUE=1

# NOTE: The Cockpit's Supabase vars (VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY)
# are intentionally NOT committed here — set them as Vercel project env vars on
# the cockpit deploy. Locally they live in .env.local (gitignored).
