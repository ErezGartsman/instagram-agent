# DataLens — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required
GEMINI_API_KEY=
# Supabase pooler connection string (session mode), e.g.
# postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# API Authentication
# Leave empty to disable auth (local dev).
# In production, generate with: openssl rand -hex 32
NEXUS_API_KEY=

# Telegram bot (optional — webhook is inert until BOTH are set)
# TELEGRAM_BOT_TOKEN:      from BotFather (/newbot)
# TELEGRAM_WEBHOOK_SECRET: generate with openssl rand -hex 32, then register:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#        -d "url=https://<your-app>.vercel.app/api/webhook/telegram" \
#        -d "secret_token=<TELEGRAM_WEBHOOK_SECRET>"
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# P2 Ambient Copilot (optional — Copilot endpoints return 503 until set)
# ANTHROPIC_API_KEY: powers the cockpit drafting Copilot (Claude). The Gemini
#   formation cron is unaffected. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=
COPILOT_TIMEOUT_SECONDS=60

# Optional (these are the defaults)
MAX_RESULT_ROWS=500
ALLOWED_ORIGINS=http://localhost:5173
